# ============================================================
# CrisisLens v2.0 — 環境變數設定範本
# 使用方式：cp .env.example .env  然後填入真實值
# 注意：.env 已加入 .gitignore，請勿 commit 真實金鑰
# ============================================================

# ── Gemini API ───────────────────────────────────────────────
# RAG 生成建議 + Safety Guard 語意分析後端
# 申請：https://aistudio.google.com/app/apikey
# 不填也能使用，RAG 改用內建應變指引（不呼叫 LLM）
GEMINI_API_KEY=your_gemini_api_key_here

# ── Safety Guard / ShieldGemma ───────────────────────────────
# false：keyword + Gemini fallback（較輕量，適合 demo 與雲端部署）
# true ：啟用本機 ShieldGemma-2b（需 GPU / 大量記憶體）
USE_LOCAL_SHIELDGEMMA=false
SHIELDGEMMA_MODEL=google/shieldgemma-2b

# ── 初始管理員帳號 ───────────────────────────────────────────
# 僅在 users 表為空時建立。正式部署請務必設定強密碼。
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=

# ── 資料庫 ───────────────────────────────────────────────────
# 本機開發：留空 → 自動使用 SQLite（crisislens.db）
# Azure 部署：填入 PostgreSQL 連線字串
# 格式：postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
# Azure Database for PostgreSQL 連線字串在 Azure Portal → Access Keys 取得
DATABASE_URL=

# ── Azure Blob Storage（圖片雲端儲存，選用）──────────────────
# 本機開發：留空 → 圖片儲存至本機 uploads/reports/
# Azure 部署：填入 Blob Storage 連線字串（Portal → Storage Accounts → Access Keys）
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=crisislens-uploads

# ── Streamlit 部署安全設定 ────────────────────────────────────
# 正式部署必須設定，防止 session cookie 被偽造
# 產生方式：python -c "import secrets; print(secrets.token_hex(32))"
# Azure Container Apps 設定位置：環境變數 STREAMLIT_SERVER_COOKIE_SECRET
STREAMLIT_SERVER_COOKIE_SECRET=change_this_to_a_random_64_char_hex_string

# ── 應用行為（選用）──────────────────────────────────────────
# 每用戶每小時最多可送出的回報數（預設 10）
# REPORT_RATE_LIMIT=10
# REPORT_RATE_WINDOW_MINUTES=60
